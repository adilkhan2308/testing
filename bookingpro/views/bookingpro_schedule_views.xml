<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bookingpro_staff_schedule_tree" model="ir.ui.view">
        <field name="name">bookingpro.staff.schedule.list</field>
        <field name="model">bookingpro.staff.schedule</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="staff_user_id"/>
                <field name="weekday"/>
                <field name="hour_from" widget="float_time"/>
                <field name="hour_to" widget="float_time"/>
                <field name="break_hour_from" widget="float_time"/>
                <field name="break_hour_to" widget="float_time"/>
                <field name="active"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_bookingpro_staff_schedule_form" model="ir.ui.view">
        <field name="name">bookingpro.staff.schedule.form</field>
        <field name="model">bookingpro.staff.schedule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="staff_user_id"/>
                            <field name="employee_id"/>
                            <field name="weekday"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="hour_from" widget="float_time"/>
                            <field name="hour_to" widget="float_time"/>
                            <field name="break_hour_from" widget="float_time"/>
                            <field name="break_hour_to" widget="float_time"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Special availability notes..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_bookingpro_staff_schedule_search" model="ir.ui.view">
        <field name="name">bookingpro.staff.schedule.search</field>
        <field name="model">bookingpro.staff.schedule</field>
        <field name="arch" type="xml">
            <search>
                <field name="staff_user_id"/>
                <field name="weekday"/>
                <filter name="active" string="Active" domain="[('active','=',True)]"/>
                <group name="group_by">
                    <filter name="staff" string="Staff" context="{'group_by':'staff_user_id'}"/>
                    <filter name="weekday" string="Weekday" context="{'group_by':'weekday'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_bookingpro_staff_schedule" model="ir.actions.act_window">
        <field name="name">Staff Availability</field>
        <field name="res_model">bookingpro.staff.schedule</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_bookingpro_staff_schedule_search"/>
    </record>
</odoo>
