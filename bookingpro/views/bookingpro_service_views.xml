<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bookingpro_service_tree" model="ir.ui.view">
        <field name="name">bookingpro.service.list</field>
        <field name="model">bookingpro.service</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="duration"/>
                <field name="price"/>
                <field name="capacity"/>
                <field name="website_published"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_bookingpro_service_form" model="ir.ui.view">
        <field name="name">bookingpro.service.form</field>
        <field name="model">bookingpro.service</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. General Consultation"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="category_id"/>
                            <field name="code"/>
                            <field name="duration"/>
                            <field name="price"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="tax_ids" widget="many2many_tags"/>
                        </group>
                        <group>
                            <field name="capacity"/>
                            <field name="buffer_before"/>
                            <field name="buffer_after"/>
                            <field name="website_published"/>
                            <field name="active"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description" widget="html"/>
                        </page>
                        <page string="Staff &amp; Resources">
                            <group>
                                <field name="staff_user_ids" widget="many2many_tags"/>
                                <field name="resource_ids" widget="many2many_tags"/>
                            </group>
                        </page>
                        <page string="Appointments">
                            <field name="appointment_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="partner_id"/>
                                    <field name="staff_user_id"/>
                                    <field name="start_datetime"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_bookingpro_service_search" model="ir.ui.view">
        <field name="name">bookingpro.service.search</field>
        <field name="model">bookingpro.service</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="category_id"/>
                <filter name="published" string="Published" domain="[('website_published','=',True)]"/>
                <filter name="archived" string="Archived" domain="[('active','=',False)]"/>
                <group name="group_by">
                    <filter name="group_by_category" string="Category" context="{'group_by':'category_id'}"/>
                    <filter name="group_by_company" string="Company" context="{'group_by':'company_id'}" groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_bookingpro_service" model="ir.actions.act_window">
        <field name="name">Services</field>
        <field name="res_model">bookingpro.service</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_bookingpro_service_search"/>
    </record>
</odoo>
