="bp-btn bp-btn-soft w-100" type="submit">Send to Read.ai</button></form><hr/><form t-att-action="'/bookingpro/workspace/appointment/%s/action' % appointment.id" method="post"><input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/><input type="hidden" name="action" value="reschedule"/><label>New Start</label><input type="datetime-local" name="new_start_datetime" class="form-control mb-2"/><label>New End</label><input type="datetime-local" name="new_end_datetime" class="form-control mb-2"/><label>Reason</label><textarea name="reason" class="form-control mb-2"></textarea><button class="bp-btn bp-btn-soft w-100" type="submit">Reschedule</button></form></div></div>
