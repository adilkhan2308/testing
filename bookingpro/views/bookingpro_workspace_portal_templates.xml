    <template id="portal_workspace_smtp" name="BookingPro Premium SMTP">
        <t t-set="page_title">Email / SMTP Center</t><t t-set="page_subtitle">Create, test and assign outgoing mail servers from the portal, without opening Odoo backend settings.</t><t t-call="bookingpro.portal_workspace_frame"><t t-if="smtp_settings.get('status') == 'saved'"><div class="bp-alert bp-alert-success">SMTP settings saved successfully. BookingPro emails will use this server.</div></t><t t-if="smtp_settings.get('status') == 'test_sent'"><div class="bp-alert bp-alert-success">Test email has been sent/queued successfully.</div></t><t t-if="smtp_settings.get('status') == 'error'"><div class="bp-alert bp-alert-danger"><strong>SMTP Error:</strong> <t t-out="smtp_settings.get('message')"/></div></t><div class="bp-grid" style="grid-template-columns:1.2fr .8fr;"><div><div class="bp-card mb-4"><div class="bp-card-header"><h3 class="bp-card-title">Outgoing Mail Servers</h3><span class="bp-badge bp-badge-info">Portal Managed</span></div><div class="bp-card-body p-0"><table class="bp-table"><thead><tr><th>Name</th><th>Host</th><th>Port</th><th>Encryption</th><th>Active</th><th></th></tr></thead><tbody><t t-if="not smtp_servers"><tr><td colspan="6"><div class="bp-empty">No outgoing mail server configured yet.</div></td></tr></t><t t-foreach="smtp_servers" t-as="server"><tr><td><strong><t t-out="server.name"/></strong></td><td><t t-out="server.smtp_host"/></td><td><t t-out="server.smtp_port"/></td><td><t t-out="server.smtp_encryption"/></td><td><span t-attf-class="bp-badge #{'bp-badge-ok' if server.active else 'bp-badge-muted'}"><t t-out="'Active' if server.active else 'Inactive'"/></span></td><td><form action="/bookingpro/workspace/smtp" method="post"><input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/><input type="hidden" name="action" value="select"/><input type="hidden" name="mail_server_id" t-att-value="server.id"/><input type="hidden" name="smtp_from_email" t-att-value="smtp_settings.get('from_email')"/><input type="hidden" name="smtp_from_name" t-att-value="smtp_settings.get('from_name')"/><button class="bp-btn bp-btn-soft" type="submit">Use</button></form></td></tr></t></tbody></table></div></div><div class="bp-card"><div class="bp-card-header"><h3 class="bp-card-title">Send Test Email</h3></div><div class="bp-card-body bp-form"><form action="/bookingpro/workspace/smtp" method="post" class="row g-2"><input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/><input type="hidden" name="action" value="test"/><input type="hidden" name="mail_server_id" t-att-value="smtp_selected_server.id if smtp_selected_server else ''"/><input type="hidden" name="smtp_from_email" t-att-value="smtp_settings.get('from_email')"/><input type="hidden" name="smtp_from_name" t-att-value="smtp_settings.get('from_name')"/><div class="col-md-8"><input name="test_email" type="email" class="form-control" placeholder="test@example.com" t-att-value="request.env.user.email or ''" required="required"/></div><div class="col-md-4"><button class="bp-btn bp-btn-success w-100" type="submit">Send Test</button></div></form></div></div></div><div class="bp-card bp-form-card"><div class="bp-card-header"><h3 class="bp-card-title">Create / Update SMTP</h3></div><div class="bp-card-body bp-form"><form action="/bookingpro/workspace/smtp" method="post"><input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/><input type="hidden" name="action" value="save"/><label>Update Existing</label><select name="mail_server_id" class="form-select mb-3"><option value="">Create New SMTP Server</option><t t-foreach="smtp_servers" t-as="server"><option t-att-value="server.id" t-att-selected="smtp_selected_server and server.id == smtp_selected_server.id and 'selected' or None"><t t-out="server.name"/></option></t></select><label>SMTP Name</label><input name="smtp_name" class="form-control mb-3" t-att-value="smtp_selected_server.name if smtp_selected_server else 'BookingPro SMTP'" required="required"/><label>SMTP Host</label><input name="smtp_host" class="form-control mb-3" t-att-value="smtp_selected_server.smtp_host if smtp_selected_server else ''" placeholder="smtp.gmail.com" required="required"/><div class="row"><div class="col-6"><label>Port</label><input name="smtp_port" class="form-control mb-3" t-att-value="smtp_selected_server.smtp_port if smtp_selected_server else 587"/></div><div class="col-6"><label>Encryption</label><select name="smtp_encryption" class="form-select mb-3"><t t-foreach="smtp_encryption_selection" t-as="enc"><option t-att-value="enc[0]" t-att-selected="smtp_selected_server and smtp_selected_server.smtp_encryption == enc[0] and 'selected' or None"><t t-out="enc[1]"/></option></t></select></div></div><label>Username</label><input name="smtp_user" class="form-control mb-3" t-att-value="smtp_selected_server.smtp_user if smtp_selected_server else ''"/><label>Password</label><input name="smtp_pass" class="form-control mb-3" type="password" placeholder="Leave empty to keep existing password"/><label>From Email</label><input name="smtp_from_email" type="email" class="form-control mb-3" t-att-value="smtp_settings.get('from_email')" placeholder="noreply@yourdomain.com"/><label>From Name</label><input name="smtp_from_name" class="form-control mb-3" t-att-value="smtp_settings.get('from_name')"/><label>From Filter</label><input name="smtp_from_filter" class="form-control mb-3" t-att-value="smtp_selected_server.from_filter if smtp_selected_server and 'from_filter' in smtp_selected_server._fields else ''" placeholder="@yourdomain.com"/><label>Sequence</label><input name="smtp_sequence" class="form-control mb-3" t-att-value="smtp_selected_server.sequence if smtp_selected_server else 10"/><div class="form-check mb-3"><input class="form-check-input" type="checkbox" name="smtp_active" checked="checked"/><label class="form-check-label">Active</label></div><button class="bp-btn bp-btn-primary w-100" type="submit">Save SMTP and Use for BookingPro</button></form></div></div></div></t>
    </template>

    <template id="portal_workspace_settings" name="BookingPro Premium Settings">
        <t t-set="page_title">Portal Settings</t><t t-set="page_subtitle">Configure tenant booking link, CRM lead capture, reminders, follow-up intervals, Read.ai and portal behavior.</t><t t-call="bookingpro.portal_workspace_frame"><t t-if="saved"><div class="bp-alert bp-alert-success">Settings saved successfully.</div></t><div class="bp-card"><div class="bp-card-header"><h3 class="bp-card-title">BookingPro Settings</h3><span class="bp-badge bp-badge-info">Tenant Controlled</span></div><div class="bp-card-body bp-form"><form action="/bookingpro/workspace/settings" method="post"><input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/><div class="bp-grid bp-grid-4"><div><label>Client Booking Slug</label><input name="bookingpro_slug" class="form-control mb-3" t-att-value="bookingpro_company.bookingpro_slug"/></div><div><label>Public Booking Link</label><input id="bp-settings-link" class="form-control mb-3" t-att-value="bookingpro_public_url" readonly="readonly"/></div><div><label>Slot Step Minutes</label><input name="slot_step_minutes" class="form-control mb-3" t-att-value="bookingpro_settings['slot_step_minutes']"/></div><div><label>Follow-up Delay Days</label><input name="followup_delay_days" class="form-control mb-3" t-att-value="bookingpro_settings['followup_delay_days']"/></div><div><label>Customer Follow-up Interval</label><select name="customer_followup_interval_hours" class="form-select mb-3"><option value="1" t-att-selected="bookingpro_settings['customer_followup_interval_hours'] == '1' and 'selected' or None">Every 1 hour</option><option value="5" t-att-selected="bookingpro_settings['customer_followup_interval_hours'] == '5' and 'selected' or None">Every 5 hours</option></select></div><div><label>Max Follow-up Emails</label><input name="customer_followup_max_emails" class="form-control mb-3" t-att-value="bookingpro_settings['customer_followup_max_emails']"/></div><div><label>Read.ai Webhook/API URL</label><input name="readai_api_url" class="form-control mb-3" t-att-value="bookingpro_settings['readai_api_url']"/></div><div><label>Read.ai API Key</label><input name="readai_api_key" class="form-control mb-3" type="password"/></div></div><hr/><div class="bp-grid bp-grid-4"><t t-foreach="[('auto_confirm','Auto Confirm'),('require_payment','Require Payment'),('create_crm_lead','Create CRM Lead'),('auto_followup','Auto Internal Follow-up'),('enable_customer_followup','Enable Customer Follow-up'),('auto_customer_followup_on_booking','Auto Follow-up on Booking'),('send_customer_followup_email_on_booking','Send Booking Follow-up Email'),('send_customer_followup_after_completion','Send Completion Follow-up Email'),('create_internal_activity_for_customer_followup','Create Internal Follow-up Activity'),('enable_reminders','Email Reminders'),('send_5h','5 Hour Reminder'),('send_1h','1 Hour Reminder'),('readai_enabled','Enable Read.ai Hook')]" t-as="setting"><div class="form-check"><input class="form-check-input" type="checkbox" t-att-name="'bookingpro_%s' % setting[0]" t-att-checked="bookingpro_settings[setting[0]] and 'checked' or None"/><label class="form-check-label"><t t-out="setting[1]"/></label></div></t></div><button class="bp-btn bp-btn-primary mt-4" type="submit">Save Settings</button></form></div></div></t>
    </template>
</odoo>
