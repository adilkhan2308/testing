<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_workspace_frame" name="BookingPro Premium Workspace Frame">
        <t t-call="website.layout">
            <div class="bp-command-bar bp-command-admin" data-bookingpro-command-bar="admin">
                <div class="bp-command-left">
                    <span class="bp-command-logo">BP</span>
                    <div>
                        <strong>BookingPro Workspace</strong>
                        <small>Admin / Booking Manager</small>
                    </div>
                </div>
                <div class="bp-command-actions">
                    <a class="bp-command-btn bp-command-btn-soft" href="/bookingpro/backend">Backend</a>
                    <a class="bp-command-btn bp-command-btn-primary" t-att-href="bookingpro_public_url" target="_blank">Booking Page</a>
                    <a class="bp-command-btn bp-command-btn-danger" href="/web/session/logout?redirect=/bookingpro/login">Logout</a>
                </div>
            </div>
            <div class="bp-shell bp-shell-with-command">
                <aside class="bp-sidebar">
                    <a href="/bookingpro/workspace" class="bp-brand">
                        <div class="bp-logo">BP</div>
                        <div>
                            <h3>BookingPro</h3>
                            <span><t t-out="bookingpro_company.name"/> · <t t-out="bookingpro_role"/></span>
                        </div>
                    </a>
                    <div class="bp-nav-label">Workspace</div>
                    <nav class="bp-nav">
                        <a t-attf-class="bp-nav-link #{'active' if page_section == 'dashboard' else ''}" href="/bookingpro/workspace">▣ Dashboard</a>
                        <a t-attf-class="bp-nav-link #{'active' if page_section == 'appointments' else ''}" href="/bookingpro/workspace/appointments">◷ Appointments</a>
                        <a t-attf-class="bp-nav-link #{'active' if page_section == 'services' else ''}" href="/bookingpro/workspace/services">✦ Services</a>
                        <a t-attf-class="bp-nav-link #{'active' if page_section == 'resources' else ''}" href="/bookingpro/workspace/resources">▤ Resources</a>
                        <a t-attf-class="bp-nav-link #{'active' if page_section == 'availability' else ''}" href="/bookingpro/workspace/availability">☷ Staff Availability</a>
                        <a t-attf-class="bp-nav-link #{'active' if page_section == 'leads' else ''}" href="/bookingpro/workspace/leads">◎ CRM Leads</a>
                    </nav>
                    <div class="bp-nav-label" t-if="bookingpro_is_manager">Administration</div>
                    <nav class="bp-nav" t-if="bookingpro_is_manager">
                        <a t-attf-class="bp-nav-link #{'active' if page_section == 'settings' else ''}" href="/bookingpro/workspace/settings">⚙ Settings</a>
                        <a t-attf-class="bp-nav-link #{'active' if page_section == 'smtp' else ''}" href="/bookingpro/workspace/smtp">✉ Email / SMTP</a>
                    </nav>
                    <div class="bp-sidebar-footer">
                        <div class="fw-bold mb-1">Public Booking Link</div>
                        <div class="small opacity-75 text-truncate" id="bp-public-link"><t t-out="bookingpro_public_url"/></div>
                        <div class="d-flex gap-2 mt-3">
                            <a class="bp-btn bp-btn-soft bp-copy-field" t-att-href="bookingpro_public_url" target="_blank">Open</a>
                            <button class="bp-btn bp-btn-soft bp-copy-field" data-bp-copy="#bp-public-link">Copy</button>
                        </div>
                    </div>
                </aside>
                <main class="bp-main">
                    <div class="bp-topbar">
                        <div>
                            <div class="bp-eyebrow">BookingPro Portal Workspace</div>
                            <h1 class="bp-title"><t t-out="page_title or 'Workspace'"/></h1>
                            <p class="bp-subtitle"><t t-out="page_subtitle or 'Manage appointments, services, resources, staff, CRM, follow-ups and SMTP from one custom portal.'"/></p>
                        </div>
                        <div class="bp-actions bp-top-actions">
                            <a class="bp-btn bp-btn-primary" t-att-href="bookingpro_public_url" target="_blank">Open Booking Page</a>
                        </div>
                    </div>
                    <t t-out="0"/>
                </main>
            </div>
        </t>
    </template>

    <template id="portal_workspace_nav" name="BookingPro Workspace Navigation">
        <div></div>
    </template>

    <template id="portal_workspace_error" name="BookingPro Workspace Error">
        <t t-set="page_title">Action Error</t>
        <t t-set="page_subtitle">The requested portal action could not be completed.</t>
        <t t-call="bookingpro.portal_workspace_frame">
            <div class="bp-alert bp-alert-danger"><strong>Action could not be completed.</strong><br/><t t-out="error_message"/></div>
            <a class="bp-btn bp-btn-soft" href="/bookingpro/workspace">Back to workspace</a>
        </t>
    </template>

    <template id="portal_workspace_dashboard" name="BookingPro Premium Dashboard">
        <t t-set="page_title">Executive Dashboard</t>
        <t t-set="page_subtitle">A high-level operational view of bookings, pending actions, CRM leads and service setup.</t>
        <t t-call="bookingpro.portal_workspace_frame">
            <section class="bp-grid bp-grid-4 mb-4">
                <div class="bp-stat"><div class="label">Total Bookings</div><div class="value"><t t-out="total_appointments"/></div><div class="hint">All appointments</div></div>
                <div class="bp-stat"><div class="label">Pending</div><div class="value"><t t-out="pending_count"/></div><div class="hint">Need action</div></div>
                <div class="bp-stat"><div class="label">Confirmed</div><div class="value"><t t-out="confirmed_count"/></div><div class="hint">Scheduled</div></div>
                <div class="bp-stat"><div class="label">Completed</div><div class="value"><t t-out="completed_count"/></div><div class="hint">Closed bookings</div></div>
            </section>
            <section class="bp-grid bp-grid-2">
                <div class="bp-card">
                    <div class="bp-card-header"><div><h3 class="bp-card-title">Upcoming Appointments</h3><div class="bp-card-subtitle">Next scheduled customer visits</div></div><a class="bp-link" href="/bookingpro/workspace/appointments">View all</a></div>
                    <div class="bp-card-body p-0">
                        <table class="bp-table"><thead><tr><th>Reference</th><th>Customer</th><th>Service</th><th>Date</th><th>Status</th></tr></thead><tbody>
                            <t t-if="not upcoming_appointments"><tr><td colspan="5"><div class="bp-empty">No upcoming appointments.</div></td></tr></t>
                            <t t-foreach="upcoming_appointments" t-as="appointment"><tr>
                                <td><a class="bp-link" t-att-href="'/bookingpro/workspace/appointment/%s' % appointment.id"><t t-out="appointment.name"/></a></td>
                                <td><t t-out="appointment.partner_id.name"/></td><td><t t-out="appointment.service_id.name"/></td><td><t t-out="appointment.start_datetime"/></td>
                                <td><span class="bp-badge bp-badge-info"><t t-out="dict(appointment._fields['state'].selection).get(appointment.state)"/></span></td>
                            </tr></t>
                        </tbody></table>
                    </div>
                </div>
                <div class="bp-card">
                    <div class="bp-card-header"><div><h3 class="bp-card-title">Pending Actions</h3><div class="bp-card-subtitle">Confirmations, reschedules and follow-ups</div></div></div>
                    <div class="bp-card-body">
                        <t t-if="not pending_appointments"><div class="bp-empty">No pending actions.</div></t>
                        <t t-foreach="pending_appointments" t-as="appointment">
                            <a class="bp-kpi-line text-decoration-none" t-att-href="'/bookingpro/workspace/appointment/%s' % appointment.id">
                                <span><strong><t t-out="appointment.name"/></strong><br/><small class="text-muted"><t t-out="appointment.partner_id.name"/> · <t t-out="appointment.service_id.name"/></small></span>
                                <span class="bp-badge bp-badge-warn"><t t-out="dict(appointment._fields['state'].selection).get(appointment.state)"/></span>
                            </a>
                        </t>
                    </div>
                </div>
                <div class="bp-card">
                    <div class="bp-card-header"><h3 class="bp-card-title">Services Snapshot</h3><a class="bp-link" href="/bookingpro/workspace/services">Manage</a></div>
                    <div class="bp-card-body">
                        <t t-if="not services"><div class="bp-empty">No services configured yet.</div></t>
                        <t t-foreach="services" t-as="service"><div class="bp-kpi-line"><span><strong><t t-out="service.name"/></strong><br/><small class="text-muted"><t t-out="service.duration"/> hour(s) · <t t-out="service.category_id.name"/></small></span><span class="bp-chip"><t t-out="len(service.staff_user_ids)"/> staff</span></div></t>
                    </div>
                </div>
                <div class="bp-card">
                    <div class="bp-card-header"><h3 class="bp-card-title">Client Booking Link</h3><span class="bp-badge bp-badge-ok">Live</span></div>
                    <div class="bp-card-body">
                        <p class="text-muted">Share this tenant-specific URL with customers.</p>
                        <input id="bp-dashboard-link" class="form-control rounded-4" t-att-value="bookingpro_public_url" readonly="readonly"/>
                        <div class="bp-actions-row mt-3"><button class="bp-btn bp-btn-soft" data-bp-copy="#bp-dashboard-link">Copy Link</button><a class="bp-btn bp-btn-primary" t-att-href="bookingpro_public_url" target="_blank">Open</a></div>
                    </div>
                </div>
            </section>
        </t>
    </template>

    <template id="portal_workspace_services" name="BookingPro Premium Services">
        <t t-set="page_title">Services &amp; Categories</t>
        <t t-set="page_subtitle">Create, update and publish service categories and appointment services from the portal.</t>
        <t t-call="bookingpro.portal_workspace_frame">
            <div class="bp-grid" style="grid-template-columns:1.25fr .75fr;">
                <div class="bp-card">
                    <div class="bp-card-header"><div><h3 class="bp-card-title">Services</h3><div class="bp-card-subtitle">Website-visible appointment products</div></div><input class="bp-search-input" placeholder="Search services..." data-bp-table-search="#bp-services-table"/></div>
                    <div class="bp-card-body p-0"><table id="bp-services-table" class="bp-table"><thead><tr><th>Name</th><th>Category</th><th>Duration</th><th>Price</th><th>Staff</th><th>Status</th><th></th></tr></thead><tbody>
                        <t t-if="not services"><tr><td colspan="7"><div class="bp-empty">No services yet.</div></td></tr></t>
                        <t t-foreach="services" t-as="service"><tr><td><strong><t t-out="service.name"/></strong></td><td><t t-out="service.category_id.name"/></td><td><t t-out="service.duration"/>h</td><td><t t-out="service.price"/></td><td><t t-out="', '.join(service.staff_user_ids.mapped('name')) or '-'"/></td><td><span t-attf-class="bp-badge #{'bp-badge-ok' if service.website_published and service.active else 'bp-badge-muted'}"><t t-out="'Published' if service.website_published and service.active else 'Hidden'"/></span></td><td><a class="bp-link" t-att-href="'/bookingpro/workspace/services?edit_service_id=%s' % service.id">Edit</a></td></tr></t>
                    </tbody></table></div>
                    <div class="bp-card-body border-top"><h4 class="bp-card-title mb-3">Categories</h4><table class="bp-table"><thead><tr><th>Name</th><th>Status</th><th>Services</th><th></th></tr></thead><tbody><t t-if="not categories"><tr><td colspan="4"><div class="bp-empty">No categories yet.</div></td></tr></t><t t-foreach="categories" t-as="category"><tr><td><strong><t t-out="category.name"/></strong></td><td><span t-attf-class="bp-badge #{'bp-badge-ok' if category.website_published and category.active else 'bp-badge-muted'}"><t t-out="'Published' if category.website_published and category.active else 'Hidden'"/></span></td><td><t t-out="category.service_count"/></td><td><a class="bp-link" t-att-href="'/bookingpro/workspace/services?edit_category_id=%s' % category.id">Edit</a></td></tr></t></tbody></table></div>
                </div>
                <div class="bp-card bp-form-card" t-if="bookingpro_is_manager">
                    <div class="bp-card-header"><h3 class="bp-card-title"><t t-out="'Update Service' if selected_service else 'Create Service'"/></h3></div>
                    <div class="bp-card-body bp-form">
                        <form action="/bookingpro/workspace/service/save" method="post">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/><input type="hidden" name="service_id" t-att-value="selected_service.id if selected_service else ''"/>
                            <label>Name</label><input name="name" class="form-control mb-3" required="required" t-att-value="selected_service.name if selected_service else ''"/>
                            <label>Category</label><select name="category_id" class="form-select mb-3" required="required"><t t-foreach="categories" t-as="category"><option t-att-value="category.id" t-att-selected="selected_service and selected_service.category_id.id == category.id and 'selected' or None"><t t-out="category.name"/></option></t></select>
                            <div class="row"><div class="col-6"><label>Duration</label><input name="duration" class="form-control mb-3" t-att-value="selected_service.duration if selected_service else 1.0"/></div><div class="col-6"><label>Price</label><input name="price" class="form-control mb-3" t-att-value="selected_service.price if selected_service else 0.0"/></div></div>
                            <div class="row"><div class="col-6"><label>Buffer Before</label><input name="buffer_before" class="form-control mb-3" t-att-value="selected_service.buffer_before if selected_service else 0.0"/></div><div class="col-6"><label>Buffer After</label><input name="buffer_after" class="form-control mb-3" t-att-value="selected_service.buffer_after if selected_service else 0.0"/></div></div>
                            <label>Capacity</label><input name="capacity" class="form-control mb-3" t-att-value="selected_service.capacity if selected_service else 1"/>
                            <label>Description</label><textarea name="description" class="form-control mb-3"><t t-out="selected_service.description if selected_service else ''"/></textarea>
                            <label>Assigned Staff</label><select name="staff_user_ids" multiple="multiple" class="form-select mb-3"><t t-foreach="staff_users" t-as="staff"><option t-att-value="staff.id" t-att-selected="selected_service and staff.id in selected_service.staff_user_ids.ids and 'selected' or None"><t t-out="staff.name"/></option></t></select>
                            <label>Allowed Resources</label><select name="resource_ids" multiple="multiple" class="form-select mb-3"><t t-foreach="resources" t-as="resource"><option t-att-value="resource.id" t-att-selected="selected_service and resource.id in selected_service.resource_ids.ids and 'selected' or None"><t t-out="resource.name"/></option></t></select>
                            <div class="d-flex gap-3 mb-3"><div class="form-check"><input class="form-check-input" type="checkbox" name="website_published" t-att-checked="(selected_service.website_published if selected_service else True) and 'checked' or None"/><label class="form-check-label">Published</label></div><div class="form-check"><input class="form-check-input" type="checkbox" name="active" t-att-checked="(selected_service.active if selected_service else True) and 'checked' or None"/><label class="form-check-label">Active</label></div></div>
                            <button class="bp-btn bp-btn-primary w-100" type="submit"><t t-out="'Update Service' if selected_service else 'Save Service'"/></button><t t-if="selected_service"><a class="bp-btn bp-btn-soft w-100 mt-2" href="/bookingpro/workspace/services">Cancel Edit</a></t>
                        </form>
                        <hr/>
                        <h3 class="bp-card-title mb-3"><t t-out="'Update Category' if selected_category else 'Create Category'"/></h3>
                        <form action="/bookingpro/workspace/category/save" method="post"><input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/><input type="hidden" name="category_id" t-att-value="selected_category.id if selected_category else ''"/><label>Name</label><input name="name" class="form-control mb-3" required="required" t-att-value="selected_category.name if selected_category else ''"/><label>Description</label><textarea name="description" class="form-control mb-3"><t t-out="selected_category.description if selected_category else ''"/></textarea><div class="d-flex gap-3 mb-3"><div class="form-check"><input class="form-check-input" type="checkbox" name="website_published" t-att-checked="(selected_category.website_published if selected_category else True) and 'checked' or None"/><label class="form-check-label">Published</label></div><div class="form-check"><input class="form-check-input" type="checkbox" name="active" t-att-checked="(selected_category.active if selected_category else True) and 'checked' or None"/><label class="form-check-label">Active</label></div></div><button class="bp-btn bp-btn-soft w-100" type="submit"><t t-out="'Update Category' if selected_category else 'Save Category'"/></button></form>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <template id="portal_workspace_resources" name="BookingPro Premium Resources">
        <t t-set="page_title">Resources</t><t t-set="page_subtitle">Manage rooms, equipment, chairs, courts, vehicles or any bookable resource from the portal.</t>
        <t t-call="bookingpro.portal_workspace_frame">
            <div class="bp-grid" style="grid-template-columns:1.35fr .65fr;">
                <div class="bp-card"><div class="bp-card-header"><h3 class="bp-card-title">Bookable Resources</h3><input class="bp-search-input" placeholder="Search resources..." data-bp-table-search="#bp-resources-table"/></div><div class="bp-card-body p-0"><table id="bp-resources-table" class="bp-table"><thead><tr><th>Name</th><th>Type</th><th>Location</th><th>Capacity</th><th>Services</th><th>Status</th><th></th></tr></thead><tbody><t t-if="not resources"><tr><td colspan="7"><div class="bp-empty">No resources yet.</div></td></tr></t><t t-foreach="resources" t-as="resource"><tr><td><strong><t t-out="resource.name"/></strong></td><td><t t-out="dict(resource._fields['resource_type'].selection).get(resource.resource_type)"/></td><td><t t-out="resource.location or '-'"/></td><td><t t-out="resource.capacity"/></td><td><t t-out="', '.join(resource.service_ids.mapped('name')) or '-'"/></td><td><span t-attf-class="bp-badge #{'bp-badge-ok' if resource.active else 'bp-badge-muted'}"><t t-out="'Active' if resource.active else 'Inactive'"/></span></td><td><a class="bp-link" t-att-href="'/bookingpro/workspace/resources?edit_resource_id=%s' % resource.id">Edit</a></td></tr></t></tbody></table></div></div>
                <div class="bp-card bp-form-card" t-if="bookingpro_is_manager"><div class="bp-card-header"><h3 class="bp-card-title"><t t-out="'Update Resource' if selected_resource else 'Create Resource'"/></h3></div><div class="bp-card-body bp-form"><form action="/bookingpro/workspace/resource/save" method="post"><input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/><input type="hidden" name="resource_id" t-att-value="selected_resource.id if selected_resource else ''"/><label>Name</label><input name="name" class="form-control mb-3" required="required" t-att-value="selected_resource.name if selected_resource else ''"/><label>Type</label><select name="resource_type" class="form-select mb-3"><t t-foreach="request.env['bookingpro.resource']._fields['resource_type'].selection" t-as="rtype"><option t-att-value="rtype[0]" t-att-selected="selected_resource and selected_resource.resource_type == rtype[0] and 'selected' or None"><t t-out="rtype[1]"/></option></t></select><label>Location</label><input name="location" class="form-control mb-3" t-att-value="selected_resource.location if selected_resource else ''"/><label>Capacity</label><input name="capacity" class="form-control mb-3" t-att-value="selected_resource.capacity if selected_resource else 1"/><label>Description</label><textarea name="description" class="form-control mb-3"><t t-out="selected_resource.description if selected_resource else ''"/></textarea><label>Services</label><select name="service_ids" multiple="multiple" class="form-select mb-3"><t t-foreach="services" t-as="service"><option t-att-value="service.id" t-att-selected="selected_resource and service.id in selected_resource.service_ids.ids and 'selected' or None"><t t-out="service.name"/></option></t></select><div class="form-check mb-3"><input class="form-check-input" type="checkbox" name="active" t-att-checked="(selected_resource.active if selected_resource else True) and 'checked' or None"/><label class="form-check-label">Active</label></div><button class="bp-btn bp-btn-primary w-100" type="submit"><t t-out="'Update Resource' if selected_resource else 'Save Resource'"/></button><t t-if="selected_resource"><a class="bp-btn bp-btn-soft w-100 mt-2" href="/bookingpro/workspace/resources">Cancel Edit</a></t></form></div></div>
            </div>
        </t>
    </template>

    <template id="portal_workspace_availability" name="BookingPro Premium Availability">
        <t t-set="page_title">Staff Availability</t><t t-set="page_subtitle">Control staff working days, breaks and time windows so the website shows accurate available slots.</t>
        <t t-call="bookingpro.portal_workspace_frame">
            <div class="bp-grid" style="grid-template-columns:1.35fr .65fr;">
                <div class="bp-card"><div class="bp-card-header"><h3 class="bp-card-title">Availability Rules</h3><input class="bp-search-input" placeholder="Search availability..." data-bp-table-search="#bp-availability-table"/></div><div class="bp-card-body p-0"><table id="bp-availability-table" class="bp-table"><thead><tr><th>Staff</th><th>Weekday</th><th>Time</th><th>Break</th><th>Status</th><th></th></tr></thead><tbody><t t-if="not schedules"><tr><td colspan="6"><div class="bp-empty">No availability rules yet.</div></td></tr></t><t t-foreach="schedules" t-as="schedule"><tr><td><strong><t t-out="schedule.staff_user_id.name"/></strong></td><td><t t-out="dict(schedule._fields['weekday'].selection).get(schedule.weekday)"/></td><td><t t-out="schedule.hour_from"/> - <t t-out="schedule.hour_to"/></td><td><t t-out="'%s - %s' % (schedule.break_hour_from, schedule.break_hour_to)"/></td><td><span t-attf-class="bp-badge #{'bp-badge-ok' if schedule.active else 'bp-badge-muted'}"><t t-out="'Active' if schedule.active else 'Inactive'"/></span></td><td><a class="bp-link" t-att-href="'/bookingpro/workspace/availability?edit_schedule_id=%s' % schedule.id">Edit</a></td></tr></t></tbody></table></div></div>
                <div class="bp-card bp-form-card" t-if="bookingpro_is_manager"><div class="bp-card-header"><h3 class="bp-card-title"><t t-out="'Update Availability' if selected_schedule else 'Create Availability'"/></h3></div><div class="bp-card-body bp-form"><form action="/bookingpro/workspace/availability/save" method="post"><input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/><input type="hidden" name="schedule_id" t-att-value="selected_schedule.id if selected_schedule else ''"/><label>Staff User</label><select name="staff_user_id" class="form-select mb-3" required="required"><t t-foreach="staff_users" t-as="staff"><option t-att-value="staff.id" t-att-selected="selected_schedule and selected_schedule.staff_user_id.id == staff.id and 'selected' or None"><t t-out="staff.name"/></option></t></select><label>Weekday</label><select name="weekday" class="form-select mb-3"><t t-foreach="weekdays" t-as="weekday"><option t-att-value="weekday[0]" t-att-selected="selected_schedule and selected_schedule.weekday == weekday[0] and 'selected' or None"><t t-out="weekday[1]"/></option></t></select><div class="row"><div class="col-6"><label>From</label><input type="time" name="hour_from" class="form-control mb-3" t-att-value="'%02d:%02d' % (int(selected_schedule.hour_from) if selected_schedule else 9, int(((selected_schedule.hour_from if selected_schedule else 9.0) % 1) * 60))"/></div><div class="col-6"><label>To</label><input type="time" name="hour_to" class="form-control mb-3" t-att-value="'%02d:%02d' % (int(selected_schedule.hour_to) if selected_schedule else 17, int(((selected_schedule.hour_to if selected_schedule else 17.0) % 1) * 60))"/></div></div><div class="row"><div class="col-6"><label>Break From</label><input type="time" name="break_hour_from" class="form-control mb-3" t-att-value="'%02d:%02d' % (int(selected_schedule.break_hour_from) if selected_schedule else 0, int(((selected_schedule.break_hour_from if selected_schedule else 0.0) % 1) * 60))"/></div><div class="col-6"><label>Break To</label><input type="time" name="break_hour_to" class="form-control mb-3" t-att-value="'%02d:%02d' % (int(selected_schedule.break_hour_to) if selected_schedule else 0, int(((selected_schedule.break_hour_to if selected_schedule else 0.0) % 1) * 60))"/></div></div><label>Notes</label><textarea name="notes" class="form-control mb-3"><t t-out="selected_schedule.notes if selected_schedule else ''"/></textarea><div class="form-check mb-3"><input class="form-check-input" type="checkbox" name="active" t-att-checked="(selected_schedule.active if selected_schedule else True) and 'checked' or None"/><label class="form-check-label">Active</label></div><button class="bp-btn bp-btn-primary w-100" type="submit"><t t-out="'Update Availability' if selected_schedule else 'Save Availability'"/></button><t t-if="selected_schedule"><a class="bp-btn bp-btn-soft w-100 mt-2" href="/bookingpro/workspace/availability">Cancel Edit</a></t></form></div></div>
            </div>
        </t>
