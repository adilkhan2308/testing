<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bookingpro_resource_tree" model="ir.ui.view">
        <field name="name">bookingpro.resource.list</field>
        <field name="model">bookingpro.resource</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="resource_type"/>
                <field name="location"/>
                <field name="capacity"/>
                <field name="active"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_bookingpro_resource_form" model="ir.ui.view">
        <field name="name">bookingpro.resource.form</field>
        <field name="model">bookingpro.resource</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="resource_type"/>
                            <field name="location"/>
                            <field name="capacity"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="active"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description"><field name="description"/></page>
                        <page string="Services"><field name="service_ids" widget="many2many_tags"/></page>
                        <page string="Appointments">
                            <field name="appointment_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="partner_id"/>
                                    <field name="service_id"/>
                                    <field name="start_datetime"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_bookingpro_resource" model="ir.actions.act_window">
        <field name="name">Resources</field>
        <field name="res_model">bookingpro.resource</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
