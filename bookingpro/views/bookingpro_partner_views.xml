<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_bookingpro" model="ir.ui.view">
        <field name="name">res.partner.form.bookingpro</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_bookingpro_appointments" type="object" class="oe_stat_button" icon="fa-calendar">
                    <field name="bookingpro_appointment_count" widget="statinfo" string="Appointments"/>
                </button>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="BookingPro">
                    <group>
                        <field name="bookingpro_preferred_service_ids" widget="many2many_tags"/>
                        <field name="bookingpro_last_appointment_id" readonly="1"/>
                    </group>
                    <separator string="Internal Booking Notes"/>
                    <group>
                        <field name="bookingpro_customer_note" nolabel="1"/>
                    </group>
                    <field name="bookingpro_appointment_ids" readonly="1">
                        <list>
                            <field name="name"/>
                            <field name="service_id"/>
                            <field name="staff_user_id"/>
                            <field name="start_datetime"/>
                            <field name="state" widget="badge"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
