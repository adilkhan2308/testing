<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="mail_template_appointment_received" model="mail.template">
            <field name="name">BookingPro: Appointment Received</field>
            <field name="model_id" ref="model_bookingpro_appointment"/>
            <field name="subject">Appointment request received - {{ object.name }}</field>
            <field name="email_to">{{ object.partner_id.email }}</field>
            <field name="body_html" type="html">
                <div>
                    <p>Hello <t t-out="object.partner_id.name"/>,</p>
                    <p>Your appointment request has been received.</p>
                    <ul>
                        <li><strong>Reference:</strong> <t t-out="object.name"/></li>
                        <li><strong>Service:</strong> <t t-out="object.service_id.name"/></li>
                        <li><strong>Date/Time:</strong> <t t-out="object.start_datetime"/></li>
                    </ul>
                    <p>We will confirm it shortly.</p>
                </div>
            </field>
        </record>

        <record id="mail_template_appointment_confirmed" model="mail.template">
            <field name="name">BookingPro: Appointment Confirmed</field>
            <field name="model_id" ref="model_bookingpro_appointment"/>
            <field name="subject">Appointment confirmed - {{ object.name }}</field>
            <field name="email_to">{{ object.partner_id.email }}</field>
            <field name="body_html" type="html">
                <div>
                    <p>Hello <t t-out="object.partner_id.name"/>,</p>
                    <p>Your appointment has been confirmed.</p>
                    <ul>
                        <li><strong>Reference:</strong> <t t-out="object.name"/></li>
                        <li><strong>Service:</strong> <t t-out="object.service_id.name"/></li>
                        <li><strong>Staff:</strong> <t t-out="object.staff_user_id.name or ''"/></li>
                        <li><strong>Date/Time:</strong> <t t-out="object.start_datetime"/></li>
                    </ul>
                </div>
            </field>
        </record>

        <record id="mail_template_appointment_rescheduled" model="mail.template">
            <field name="name">BookingPro: Appointment Rescheduled</field>
            <field name="model_id" ref="model_bookingpro_appointment"/>
            <field name="subject">Appointment rescheduled - {{ object.name }}</field>
            <field name="email_to">{{ object.partner_id.email }}</field>
            <field name="body_html" type="html">
                <div>
                    <p>Hello <t t-out="object.partner_id.name"/>,</p>
                    <p>Your appointment has been rescheduled.</p>
                    <ul>
                        <li><strong>Reference:</strong> <t t-out="object.name"/></li>
                        <li><strong>New Date/Time:</strong> <t t-out="object.start_datetime"/></li>
                    </ul>
                </div>
            </field>
        </record>

        <record id="mail_template_appointment_cancelled" model="mail.template">
            <field name="name">BookingPro: Appointment Cancelled</field>
            <field name="model_id" ref="model_bookingpro_appointment"/>
            <field name="subject">Appointment cancelled - {{ object.name }}</field>
            <field name="email_to">{{ object.partner_id.email }}</field>
            <field name="body_html" type="html">
                <div>
                    <p>Hello <t t-out="object.partner_id.name"/>,</p>
                    <p>Your appointment has been cancelled.</p>
                    <ul>
                        <li><strong>Reference:</strong> <t t-out="object.name"/></li>
                        <li><strong>Service:</strong> <t t-out="object.service_id.name"/></li>
                    </ul>
                </div>
            </field>
        </record>


        <record id="mail_template_appointment_reminder" model="mail.template">
            <field name="name">BookingPro: Appointment Reminder</field>
            <field name="model_id" ref="model_bookingpro_appointment"/>
            <field name="subject">Appointment reminder - {{ object.name }}</field>
            <field name="email_to">{{ object.partner_id.email }}</field>
            <field name="body_html" type="html">
                <div>
                    <p>Hello <t t-out="object.partner_id.name"/>,</p>
                    <p>This is a reminder for your upcoming appointment.</p>
                    <ul>
                        <li><strong>Reference:</strong> <t t-out="object.name"/></li>
                        <li><strong>Service:</strong> <t t-out="object.service_id.name"/></li>
                        <li><strong>Staff:</strong> <t t-out="object.staff_user_id.name or ''"/></li>
                        <li><strong>Date/Time:</strong> <t t-out="object.start_datetime"/></li>
                    </ul>
                </div>
            </field>
        </record>

        <record id="mail_template_customer_followup" model="mail.template">
            <field name="name">BookingPro: Customer Follow-up</field>
            <field name="model_id" ref="model_bookingpro_appointment"/>
            <field name="subject">Follow-up for your appointment - {{ object.name }}</field>
            <field name="email_to">{{ object.partner_id.email }}</field>
            <field name="body_html" type="html">
                <div>
                    <p>Hello <t t-out="object.partner_id.name"/>,</p>
                    <p>Thank you for booking with <t t-out="object.company_id.name"/>. This is a follow-up message regarding your appointment.</p>
                    <ul>
                        <li><strong>Reference:</strong> <t t-out="object.name"/></li>
                        <li><strong>Service:</strong> <t t-out="object.service_id.name"/></li>
                        <li><strong>Staff:</strong> <t t-out="object.staff_user_id.name or ''"/></li>
                        <li><strong>Date/Time:</strong> <t t-out="object.start_datetime"/></li>
                    </ul>
                    <t t-if="object.customer_followup_message">
                        <p><strong>Your follow-up note:</strong></p>
                        <p><t t-out="object.customer_followup_message"/></p>
                    </t>
                    <p>You can view your appointment from your customer portal.</p>
                    <p>Best regards,<br/><t t-out="object.company_id.name"/></p>
                </div>
            </field>
        </record>

    </data>
</odoo>
