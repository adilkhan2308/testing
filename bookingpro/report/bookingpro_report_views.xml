<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bookingpro_appointment_pivot" model="ir.ui.view">
        <field name="name">bookingpro.appointment.pivot</field>
        <field name="model">bookingpro.appointment</field>
        <field name="arch" type="xml">
            <pivot string="Appointment Analysis">
                <field name="start_datetime" type="row" interval="month"/>
                <field name="service_id" type="row"/>
                <field name="state" type="col"/>
                <field name="price" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_bookingpro_appointment_graph" model="ir.ui.view">
        <field name="name">bookingpro.appointment.graph</field>
        <field name="model">bookingpro.appointment</field>
        <field name="arch" type="xml">
            <graph string="Appointment Report" type="bar">
                <field name="start_datetime" interval="month"/>
                <field name="state"/>
                <field name="price" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_bookingpro_report_analysis" model="ir.actions.act_window">
        <field name="name">Appointment Analysis</field>
        <field name="res_model">bookingpro.appointment</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="context">{'search_default_this_month': 1}</field>
    </record>
</odoo>
